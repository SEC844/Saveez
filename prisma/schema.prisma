// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Auth
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Paramètres personnalisés
  objectifBase    Float  @default(400)  // Objectif de repli si aucun objectif temporel actif
  fondsSecurite   Float  @default(5000) // Palier "intouchable" (€)
  epargneActuelle Float  @default(0)    // Solde courant (€)
  revenuNet       Float? // Revenu mensuel net optionnel (pour suggestions d'objectifs)
  onboardingDone  Boolean @default(false) // Popup de configuration initiale affichée

  // Relations
  epargneMensuelles EpargneMensuelle[]
  imprévus          Imprevu[]
  objectifs         Objectif[]
  actionLogs        ActionLog[]
  comptes           Compte[]
  transactions      Transaction[]

  @@map("users")
}

// ─────────────────────────────────────────────
// Entrées mensuelles d'épargne
// ─────────────────────────────────────────────

model EpargneMensuelle {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  annee   Int
  mois    Int     // 1–12
  montant Float   // Somme réellement mise de côté ce mois-ci (€)
  note    String? // Note libre optionnelle
  repartition Json? // { standard: X, [compteId]: X } répartition par objectif/compte

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, annee, mois])
  @@map("epargne_mensuelles")
}

// ─────────────────────────────────────────────
// Imprévus (dépenses exceptionnelles)
// ─────────────────────────────────────────────

model Imprevu {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  nom                String  // Ex : "Machine à laver"
  montantTotal       Float   // Montant total prélevé (€)
  dureeRemboursement Int     // Durée de remboursement en mois
  montantMensuel     Float   // = montantTotal / dureeRemboursement

  moisDebut  Int // Mois (1–12) de début du remboursement
  anneeDebut Int // Année de début du remboursement

  // Suivi de progression
  montantRembourse Float   @default(0)
  estSolde         Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("imprévus")
}

// ─────────────────────────────────────────────
// Objectifs d'épargne temporels
// ─────────────────────────────────────────────

model Objectif {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  montant   Float   // Montant mensuel cible (€)
  label     String? // Description optionnelle
  categorie String  @default("standard") // "standard" | "vacances" | "autre"
  compteId  String? // FK → Compte (pour les objectifs vacances / autre)
  compte    Compte? @relation(fields: [compteId], references: [id], onDelete: SetNull)

  dateDebut DateTime  // Début de la période
  dateFin   DateTime? // Fin de la période — null = sans fin

  preset String? // "1m" | "3m" | "6m" | "1y" | "custom"

  createdAt DateTime @default(now())

  @@map("objectifs")
}

// ─────────────────────────────────────────────
// Journal des actions (historique)
// ─────────────────────────────────────────────

model ActionLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    String  // "add_epargne" | "add_imprevu" | "delete_imprevu" | "rembourser" | "add_objectif" | "update_settings" | "reset"
  label   String  // Description lisible
  montant Float?  // Montant associé (si applicable)
  meta    String? // JSON pour données supplémentaires

  createdAt DateTime @default(now())

  @@map("action_logs")
}

// ─────────────────────────────────────────────
// Comptes spéciaux (vacances, autre)
// ─────────────────────────────────────────────

model Compte {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String  // "vacances" | "autre"
  label     String  // Nom du compte (ex: "Vacances été 2026")
  actif     Boolean @default(true)
  solde     Float   @default(0) // Solde actuel du compte (€)
  couleur   String  @default("#8B5CF6") // Couleur hex du compte (pour UI)

  objectifs            Objectif[]
  transactionsSource   Transaction[] @relation("TransactionSource")
  transactionsDestination Transaction[] @relation("TransactionDestination")

  createdAt DateTime @default(now())

  @@map("comptes")
}

// ─────────────────────────────────────────────
// Transactions (retraits et transferts sur comptes)
// ─────────────────────────────────────────────

model Transaction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    String  // "retrait" | "transfert"
  montant Float   // Montant de la transaction (€)
  note    String? // Commentaire optionnel

  compteSourceId      String? // FK → Compte source (pour transferts)
  compteSource        Compte? @relation("TransactionSource", fields: [compteSourceId], references: [id], onDelete: SetNull)
  
  compteDestinationId String? // FK → Compte destination (pour transferts)
  compteDestination   Compte? @relation("TransactionDestination", fields: [compteDestinationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@map("transactions")
}