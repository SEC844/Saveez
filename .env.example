# ============================================================
#  Copie ce fichier en `.env` pour Docker Compose (dev local)
#  Ne jamais committer le fichier `.env` réel (il est dans .gitignore)
# ============================================================

# --- Base de données -----------------------------------------------------------
POSTGRES_USER=saveez_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=saveez_db

# URL utilisée par Prisma — en Docker, l'hôte est le nom du service ("db")
DATABASE_URL="postgresql://saveez_user:CHANGE_ME_STRONG_PASSWORD@db:5432/saveez_db?schema=public"

# --- Auth.js (NextAuth v5) -----------------------------------------------------
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# URL publique de l'application (sans slash final)
# En développement local :
NEXTAUTH_URL=http://localhost:3000
# En production, remplacer par votre domaine :
# NEXTAUTH_URL=https://saveez.votre-domaine.com
