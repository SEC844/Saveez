# ============================================================
#  .env.example — Template de configuration Saveez
#
#  Copie ce fichier en .env et remplis les valeurs.
#  Le fichier .env ne doit JAMAIS être committé sur Git.
#
#  Utilisé par : docker-compose.dev.yml (développement avec
#  variables externalisées). Pour le déploiement rapide,
#  docker-compose.yml contient des valeurs par défaut.
# ============================================================

# --- Base de données -----------------------------------------------------------
# Utilisé par docker-compose.dev.yml pour le service PostgreSQL
POSTGRES_USER=saveez_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=saveez_db

# URL de connexion Prisma — construite depuis les variables ci-dessus
# Format : postgresql://<user>:<password>@<host>:<port>/<db>?schema=public
# En Docker local, l'hôte est le nom du service ("db")
DATABASE_URL="postgresql://saveez_user:CHANGE_ME_STRONG_PASSWORD@db:5432/saveez_db?schema=public"

# --- Auth.js (NextAuth v5) -----------------------------------------------------
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# URL publique de l'application (sans slash final)
NEXTAUTH_URL=http://localhost:3000
# En production :
# NEXTAUTH_URL=https://saveez.votre-domaine.com

# --- 2FA (optionnel) -----------------------------------------------------------
# Clé HMAC pour les tokens de challenge 2FA (sinon NEXTAUTH_SECRET est utilisé)
# TOTP_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
